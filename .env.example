# =============================================================================
# GLIDEPLAN - ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git.
# =============================================================================

# =============================================================================
# FLASK CONFIGURATION
# =============================================================================

# Flask Secret Key - Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_very_secure_random_secret_key_here_change_this_in_production

# Base URL for share links (required when running behind a reverse proxy)
# Leave empty to auto-detect from the incoming request.
# Example: BASE_URL=https://soaring.example.com
BASE_URL=

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# PostgreSQL Configuration (used by Docker Compose)
POSTGRES_DB=gliding_forecast
POSTGRES_USER=glideplan
POSTGRES_PASSWORD=changeme_secure_password

# Database URL for application (automatically constructed in docker-compose.yaml)
# For local development: postgresql://glideplan:changeme_secure_password@localhost:5434/gliding_forecast
# For Docker: postgresql://glideplan:changeme_secure_password@postgres:5432/gliding_forecast
DATABASE_URL=postgresql://glideplan:changeme_secure_password@localhost:5434/gliding_forecast

# =============================================================================
# AI SERVICES
# =============================================================================

# OpenRouter API Key (PRIMARY) - https://openrouter.ai/keys
# Provides unified gateway with automatic fallback: Gemini → Llama → DeepSeek
OPENROUTER_API_KEY=

# Legacy Direct API Keys (OPTIONAL FALLBACK)
# Only used if OpenRouter fails. You can leave these empty if using OpenRouter.
GEMINI_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=

# =============================================================================
# WEATHER API KEYS
# =============================================================================

# IMGW-PIB (Polish National Weather Service) - no API key needed
IMGW_API_BASE_URL=https://danepubliczne.imgw.pl/api/data

# Windy API Key - https://api.windy.com/keys (free tier: 1,000 calls/month)
# Provides enhanced thermal predictions, cloud cover, wind gusts, RH, CAPE
WINDY_API_KEY=

# OpenWeatherMap API Key - https://home.openweathermap.org/api_keys (OPTIONAL)
OPENWEATHER_API_KEY=

# NOAA API Key - https://www.ncdc.noaa.gov/cdo-web/token (OPTIONAL)
NOAA_API_KEY=

# =============================================================================
# AIRSPACE APIs
# =============================================================================

# OpenAIP API Key (European airspace data) - https://www.openaip.net/
OPENAIP_API_KEY=

# =============================================================================
# EMAIL (RESEND)
# =============================================================================
# Resend API Key - https://resend.com/api-keys
# Free tier: 100 emails/day, 3,000/month
RESEND_API_KEY=re_xxxxxxxxx

# From address for transactional emails (must be verified in Resend dashboard)
RESEND_FROM_ADDRESS=login@glideplan.org
